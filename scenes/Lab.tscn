[sub_resource type="GDScript" id="GDScript_r70hd"]
script/source = "extends TextureProgressBar

@export var max_speed: float = 100.0
@export var current_speed: float = 0.0
@export var speed_change_rate: float = 3.0  # How fast the speedometer responds
@export var fill_color: Color = Color.WHITE

var target_speed: float = 0.0

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	# Set up the TextureProgressBar properties
	min_value = 0.0
	max_value = 100.0
	value = 0.0
	
	# Set fill mode for speedometer (usually radial)
	fill_mode = TextureProgressBar.FILL_CLOCKWISE
	radial_initial_angle = -30
	  # Start from bottom-left (adjust as needed)
	radial_fill_degrees = 270.0   # Fill 3/4 of the circle (adjust as needed)
	
	# Apply red tint to the progress texture
	modulate = fill_color
	
	# If you don't have separate textures, you can tint the whole bar
	# and use the same texture for both under and progress
	if texture_progress == null and texture_under != null:
		texture_progress = texture_under

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	# Smoothly interpolate current speed towards target speed
	current_speed = lerp(current_speed, target_speed, speed_change_rate * delta)
	
	# Update the progress bar value (0-100 based on speed percentage)
	var speed_percentage = (current_speed / max_speed) * 100.0
	value = clamp(speed_percentage, 0.0, 100.0)

# Call this function to set the target speed from your vehicle script
func set_speed(new_speed: float) -> void:
	target_speed = clamp(new_speed, 0.0, max_speed)

# Example: Connect to vehicle speed (remove this in actual implementation)
func _input(event: InputEvent) -> void:
	if event is InputEventKey and event.pressed:
		match event.keycode:
			KEY_UP:
				set_speed(target_speed + 10.0)
			KEY_DOWN:
				set_speed(target_speed - 10.0)
			KEY_R:
				set_speed(0.0)  # Reset to zero

\"\"\"
SETUP INSTRUCTIONS:

1. Node Setup:
   - Create a TextureProgressBar node
   - Attach this script to it

2. Texture Setup (Option 1 - Same texture):
   - Set your speedometer sprite as \"Texture Under\" 
   - Leave \"Texture Progress\" empty (script will copy it)
   - The script will tint the progress portion red

3. Texture Setup (Option 2 - Separate textures):
   - Set your original speedometer as \"Texture Under\"
   - Create a red-tinted version and set as \"Texture Progress\"
   - Set fill_color to Color.WHITE in the script

4. Adjust the radial settings:
   - radial_initial_angle: Where filling starts (0° = right, 90° = bottom, etc.)
   - radial_fill_degrees: How much of circle to fill (360° = full circle)
   
   Common speedometer configurations:
   - Bottom-left start: radial_initial_angle = 225°, radial_fill_degrees = 270°
   - Bottom start: radial_initial_angle = 270°, radial_fill_degrees = 180°
   - Left start: radial_initial_angle = 180°, radial_fill_degrees = 180°

5. Integration:
   From your vehicle script, call: speedometer.set_speed(your_vehicle_speed)
\"\"\"
"

